{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ez-clips-client",
  "version": "0.1.1",
  "identifier": "com.ez-clips-client.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ez-clips-client",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyNzhDMzc0MEVEMjU0Q0YKUldUUFZOSU9kTU40Y2pNRXoyb1BST0loM21XWjg0YkxTNURRSUEzNEZxRjFjYTlacmhqalkzL0gK",
      "endpoints": [
        "https://github.com/Trino11/ez-clips-client/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}